# 🔧 Configuration HSEGate Frontend

# API Configuration
# Remplacer localhost par l'IP du serveur en production
API_BASE_URL=http://localhost:8000/api/v1

# Admin Credentials (pour première connexion)
ADMIN_EMAIL=admin@hsegate.com
ADMIN_PASSWORD=admin123

# Port du Frontend
FRONTEND_PORT=5500

# Configuration Webcam
WEBCAM_WIDTH=1280
WEBCAM_HEIGHT=720
WEBCAM_QUALITY=0.9
WEBCAM_FORMAT=image/jpeg

# Configuration Image
MAX_IMAGE_SIZE=5242880  # 5MB en bytes
ALLOWED_FORMATS=image/jpeg,image/png,image/webp

# Configuration Upload
UPLOAD_DIR=/uploads
QR_CODE_DIR=/uploads/qrcodes
BADGE_DIR=/uploads/badges
FACE_DIR=/uploads/faces

# Configuration Matricule (Auto-généré par backend)
MATRICULE_PREFIX=HSE
MATRICULE_FORMAT=HSE-YYYY-XXXX  # Exemple: HSE-2026-0001

# Configuration Form
FORM_FIELDS=fullname,email,phone,department,position,company,blood_group,emergency_contact

# Configuration Table Travailleurs
ITEMS_PER_PAGE=10
REFRESH_INTERVAL=30000  # ms

# Configuration Modal
MODAL_ANIMATION_DURATION=300  # ms

# Configuration Thème
PRIMARY_COLOR=#0066cc
SECONDARY_COLOR=#6b21a8
SUCCESS_COLOR=#16a34a
DANGER_COLOR=#dc2626

# Configuration CORS
ALLOWED_ORIGINS=http://localhost:5500,http://localhost:3000,http://127.0.0.1:5500

# Configuration Développement
DEBUG=true
LOG_LEVEL=info
SHOW_CONSOLE_LOGS=true

# Configuration Sécurité
TOKEN_STORAGE=localStorage
TOKEN_EXPIRY=3600000  # 1 heure en ms
AUTO_REFRESH_TOKEN=true
SECURE_COOKIES=false  # true en HTTPS production

# Configuration Validation
MIN_FULLNAME_LENGTH=3
MAX_FULLNAME_LENGTH=100
PHONE_PATTERN=^[\d\s\-\+\(\)]+$
EMAIL_PATTERN=^[^\s@]+@[^\s@]+\.[^\s@]+$

# Configuration Statut Travailleur
DEFAULT_WORKER_STATUS=active
AVAILABLE_STATUSES=active,inactive,suspended,retired

# Configuration Groupe Sanguin
BLOOD_GROUPS=O+,O-,A+,A-,B+,B-,AB+,AB-
DEFAULT_BLOOD_GROUP=O+

# Configuration QR Code
QR_SIZE=300
QR_ERROR_CORRECTION=H
QR_BORDER=4

# Configuration Badge
BADGE_WIDTH=300
BADGE_HEIGHT=480
BADGE_DPI=300

# Configuration Face Recognition
FACE_ENCODING_SIZE=128
FACE_MIN_CONFIDENCE=0.6
FACE_MAX_SIZE=5242880  # 5MB

# Configuration Langage
DEFAULT_LANGUAGE=fr
AVAILABLE_LANGUAGES=fr,en
LANGUAGE_STORAGE=localStorage

# Configuration Cache
ENABLE_CACHE=true
CACHE_DURATION=3600000  # 1 heure
CACHE_KEYS=workers,incidents,reports

# Configuration Notifications
ENABLE_NOTIFICATIONS=true
NOTIFICATION_DURATION=5000  # ms
NOTIFICATION_POSITION=bottom-right

# Configuration Performance
ENABLE_LAZY_LOADING=true
ENABLE_COMPRESSION=true
ENABLE_MINIFICATION=true

# URLs Importantes
BACKEND_DOCS_URL=http://localhost:8000/docs
BACKEND_REDOC_URL=http://localhost:8000/redoc
BACKEND_OPENAPI_JSON=http://localhost:8000/openapi.json

# Configuration Docker (si applicable)
DOCKER_BACKEND_URL=http://backend:8000
DOCKER_FRONTEND_PORT=5500

# Configuration Authentification
AUTH_STRATEGY=jwt
JWT_ALGORITHM=HS256
JWT_SECRET=your-secret-key-here
JWT_EXPIRY=1h

# Configuration Base de Données (Backend)
DB_DRIVER=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hsegate
DB_USER=postgres
DB_PASSWORD=password

# Configuration Logs
LOG_FILE=frontend.log
LOG_MAX_SIZE=10485760  # 10MB
LOG_MAX_FILES=5

# Flags Fonctionnalités
FEATURE_WEBCAM=true
FEATURE_FACE_RECOGNITION=true
FEATURE_QR_CODE=true
FEATURE_BADGE=true
FEATURE_EXPORT=true
FEATURE_PRINT=true
FEATURE_DARK_MODE=false
FEATURE_MOBILE_APP=false

# Configuration Maintenance
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=System en maintenance...
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # 2h du matin

# Configuration Support
SUPPORT_EMAIL=support@hsegate.com
SUPPORT_PHONE=+33-1-23-45-67-89
SUPPORT_CHAT_ENABLED=false

# Notes de Configuration:
# - Cette file utilise le format: KEY=VALUE
# - Les commentaires commencent par #
# - Pas d'espaces autour du =
# - Les valeurs avec espaces doivent être entre guillemets
# - Les URLs doivent être sans slash final
# - Les ports doivent être un nombre valide (1-65535)
# - Les couleurs doivent être en format hexadécimal (#RRGGBB)
# - Les durées en ms doivent être des nombres entiers
# - Les patterns regex ne nécessitent pas les délimiteurs /
