{
  "info": {
    "name": "HSEGate Worker Management",
    "description": "Complete API collection for HSEGate worker management with UUID, QR codes, and face recognition",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api/v1",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "1. Login (Get Token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@hsegate.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    pm.environment.set(\"token\", pm.response.json().access_token);",
                  "    pm.test(\"Token saved\", function() {",
                  "        pm.expect(pm.environment.get(\"token\")).to.exist;",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Workers",
      "item": [
        {
          "name": "2. Create Worker",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullname\": \"Jean Dupont\",\n  \"matricule\": \"W001234\",\n  \"department\": \"Production\",\n  \"position\": \"Opérateur HSE\",\n  \"company\": \"HSEGate Corp\",\n  \"phone\": \"+24112345678\",\n  \"email\": \"jean.dupont@hsegate.com\",\n  \"emergency_contact\": \"+24187654321\",\n  \"blood_group\": \"O+\",\n  \"face_image_base64\": \"data:image/jpeg;base64,\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/workers",
              "host": ["{{base_url}}"],
              "path": ["workers"]
            }
          }
        },
        {
          "name": "3. Get All Workers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/workers",
              "host": ["{{base_url}}"],
              "path": ["workers"]
            }
          }
        },
        {
          "name": "4. Get Worker by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/workers/1",
              "host": ["{{base_url}}"],
              "path": ["workers", "1"]
            }
          }
        },
        {
          "name": "5. Get Worker by Matricule",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/workers/by-matricule/W001234",
              "host": ["{{base_url}}"],
              "path": ["workers", "by-matricule", "W001234"]
            }
          }
        },
        {
          "name": "6. Get QR Code",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/workers/1/qrcode",
              "host": ["{{base_url}}"],
              "path": ["workers", "1", "qrcode"]
            }
          }
        },
        {
          "name": "7. Register Face",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"face_image_base64\": \"data:image/jpeg;base64,\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/workers/1/face",
              "host": ["{{base_url}}"],
              "path": ["workers", "1", "face"]
            }
          }
        },
        {
          "name": "8. Update Worker",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullname\": \"Jean Dupont Updated\",\n  \"position\": \"Senior Opérateur HSE\",\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/workers/1",
              "host": ["{{base_url}}"],
              "path": ["workers", "1"]
            }
          }
        },
        {
          "name": "9. Delete Worker",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/workers/1",
              "host": ["{{base_url}}"],
              "path": ["workers", "1"]
            }
          }
        }
      ]
    }
  ]
}
